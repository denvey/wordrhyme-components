{
  "name": "@wordrhyme/auto-crud",
  "type": "module",
  "version": "1.3.9",
  "packageManager": "pnpm@10.25.0",
  "description": "Schema-first CRUD components with auto-generated tables and forms",
  "author": "wordrhyme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pixpilot/shadcn-components.git",
    "directory": "packages/auto-crud"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "clean": "git clean -xdf .cache .turbo dist",
    "clean:all": "git clean -xdf .cache .turbo dist node_modules",
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path ../../.prettierignore"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "sonner": "^2.0.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "dependencies": {
    "@formily/core": "^2.3.7",
    "@formily/json-schema": "^2.3.7",
    "@formily/react": "^2.3.7",
    "@formily/reactive": "^2.3.7",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-direction": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@wordrhyme/formily-shadcn": "workspace:*",
    "@wordrhyme/shadcn": "workspace:*",
    "@wordrhyme/shadcn-ui": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "catalog:prod",
    "cmdk": "^1.1.1",
    "lucide-react": "catalog:prod",
    "nanoid": "^5.1.6",
    "tailwind-merge": "catalog:prod",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@internal/eslint-config": "workspace:*",
    "@internal/prettier-config": "workspace:*",
    "@internal/tsconfig": "workspace:*",
    "@internal/tsdown-config": "workspace:*",
    "@internal/vitest-config": "workspace:*",
    "@storybook/react": "catalog:dev",
    "@storybook/test": "catalog:dev",
    "@tanstack/react-query": "^5.90.15",
    "@testing-library/jest-dom": "catalog:dev",
    "@testing-library/react": "catalog:dev",
    "@trpc/server": "^11.0.0",
    "@types/node": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "eslint": "catalog:dev",
    "jsdom": "catalog:dev",
    "react": "catalog:prod",
    "react-dom": "catalog:prod",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "prettier": "@internal/prettier-config"
}
