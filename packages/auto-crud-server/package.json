{
  "name": "@wordrhyme/auto-crud-server",
  "type": "module",
  "version": "1.0.2",
  "packageManager": "pnpm@10.25.0",
  "description": "tRPC server utilities for auto-crud - automatic CRUD routers for Drizzle ORM",
  "author": "wordrhyme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pixpilot/shadcn-components.git",
    "directory": "packages/auto-crud-server"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "clean": "git clean -xdf .cache .turbo dist",
    "clean:all": "git clean -xdf .cache .turbo dist node_modules",
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --check . --ignore-path ../../.gitignore"
  },
  "dependencies": {
    "date-fns": "^4.1.0"
  },
  "peerDependencies": {
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.40.0 || ^1.0.0-beta",
    "drizzle-zod": "^0.8.0 || ^1.0.0-beta",
    "superjson": "^2.0.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@internal/eslint-config": "workspace:*",
    "@internal/prettier-config": "workspace:*",
    "@internal/tsconfig": "workspace:*",
    "@internal/tsdown-config": "workspace:*",
    "@internal/vitest-config": "workspace:*",
    "@trpc/server": "^11.0.0",
    "@types/node": "catalog:dev",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "drizzle-zod": "1.0.0-beta.14-a36c63d",
    "eslint": "catalog:dev",
    "superjson": "^2.2.6",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "^4.0.18",
    "zod": "^4.1.13"
  },
  "prettier": "@internal/prettier-config"
}