{
  "extends": "@internal/tsconfig/base.json",
  "compilerOptions": {
    "checkJs": false,
    "jsx": "react-jsx",
    "lib": ["ES2022", "dom", "dom.iterable"],
    "noUncheckedIndexedAccess": false,
    "strict": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@wordrhyme/designable-core": ["../designable-core/src/index.ts"],
      "@wordrhyme/designable-core/*": ["../designable-core/src/*"],
      "@wordrhyme/designable-shared": ["../designable-shared/src/index.ts"],
      "@wordrhyme/designable-shared/*": ["../designable-shared/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "../../types/designable-react-compat.d.ts",
    "test/**/*",
    "*.config.ts",
    "*.config.js"
  ],
  "exclude": ["node_modules", "dist"]
}
